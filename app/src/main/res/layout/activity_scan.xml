<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black">

    <androidx.camera.view.PreviewView
        android:id="@+id/preview"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Viseur : fenêtre claire sur voile sombre, coins de cadrage. -->
    <fr.veripuce.app.ScanOverlayView
        android:id="@+id/overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <TextView
        android:id="@+id/scanHint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginLeft="24dp"
        android:layout_marginRight="24dp"
        android:layout_marginBottom="92dp"
        android:background="@drawable/bg_scan_hint"
        android:gravity="center"
        android:padding="14dp"
        android:textColor="@android:color/white"
        android:textSize="14sp"
        tools:text="Cadre la bande MRZ" />

    <!-- Barre du bas : lampe torche (basse lumière) + repli saisie manuelle. -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingBottom="20dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/scanManual"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/scan_manual_button"
            android:textColor="@android:color/white"
            app:icon="@android:drawable/ic_menu_edit"
            app:iconTint="@android:color/white" />

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/scanTorch"
            style="@style/Widget.Material3.Button.IconButton.Outlined"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:contentDescription="@string/scan_torch"
            android:visibility="gone"
            app:icon="@drawable/ic_flash_off"
            app:iconTint="@android:color/white"
            app:strokeColor="@android:color/white"
            tools:visibility="visible" />
    </LinearLayout>
</FrameLayout>
